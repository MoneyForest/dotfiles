[core]
    editor = vim
[color]
    branch = auto
    diff = auto
    status = auto
[user]
    name = MoneyForest
    email = kanamorishuhei@gmail.com
[alias]
    b = branch
    cm = commit
    co = checkout
    cob = checkout -b
    cp = cherry-pick
    d = diff
    dwd = diff --word-diff
    f = fetch
    gr = log --graph --date=short --decorate=short --pretty=format:'%Cgreen%h %Creset%cd %Cblue%cn %Cred%d %Creset%s'
    mg = merge
    st = status
    spr = !"f() { git log --merges --oneline --reverse --ancestry-path $1...master | grep 'Merge pull request #' | head -n 1; }; f"
    opr = "!f() { hub browse -- `git log --merges --oneline --reverse --ancestry-path $1...master | grep 'Merge pull request #' | head -n 1 | cut -f5 -d' ' | sed -e 's%#%pull/%'`; }; f"